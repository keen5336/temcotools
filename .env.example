DATABASE_URL=postgresql://ops_tools:password@localhost:5432/ops_tools

# Secret used to encrypt session cookies — generate with: openssl rand -base64 32
# Must be at least 32 characters long.
SESSION_SECRET=change-me-use-openssl-rand-base64-32

# Bootstrap admin credentials — used once by `npm run bootstrap`
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator
BOOTSTRAP_ADMIN_PIN=1234
