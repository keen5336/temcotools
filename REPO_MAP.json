    "scripts/deploy.sh"
  ],
  "service_boundaries": {
    "app_router_shell": "Next.js App Router pages and layouts gate access, render the dashboard, and host the individual tool surfaces.",
    "auth_and_session": "PIN login, encrypted cookie sessions, and admin/user authorization rules are enforced in route handlers and server helpers.",
    "admin_operations": "Admin-only APIs and UI manage internal users plus a shared filesystem-backed swap space for operational files.",
    "warehouse_tools": "The MARS tracking suite, RTV label tool, barcode generator, and report engine are separate task-focused clients sharing the same authenticated shell.",
    "mars_tracking": "MARS import, inventory, audit, and reconciliation flows preserve MARS as the authority snapshot while layering local staged state, audit evidence, and discrepancy reporting on top.",
    "data_and_persistence": "Prisma models and migrations define users, saved pipelines, and MARS tracking state against PostgreSQL.",
    "deployment_runtime": "Docker, environment variables, and bootstrap/deploy scripts turn the repo into a self-hosted internal app."
  },
  "critical_invariants": [
    "Only authenticated users may reach tool pages; admin-only pages and APIs must continue to pass through `requireAdmin()`.",
    "PINs are never stored in plaintext; bcrypt hashes are persisted and session cookies are encrypted via `iron-session`.",
    "Filesystem access for the admin file manager must remain rooted under `ADMIN_FILE_MANAGER_ROOT` and path traversal must be rejected.",
    "The MARS label flow depends on browser access to a local-network printer endpoint, so printing logic must tolerate mixed-content and LAN access constraints.",
    "MARS imports must continue to key records by `requestNumber` and preserve local-only fields such as `staged`, `lastScannedAt`, and `lastAuditSeenAt` across re-imports.",
    "Strict reconciliation mode must continue to treat the latest imported MARS batch as the authority snapshot and the latest completed audit as the physical baseline.",
    "Prisma migrations and generated client state must stay aligned with the deployed PostgreSQL schema before the app boots.",
    "Bootstrap admin creation is environment-driven and must remain idempotent so first-run setup can be repeated safely."
  ],
  "known_risks": [
    "The RTV label tool is client-heavy and stores template state in localStorage, which can drift across operator machines and browser sessions.",
    "Direct browser printing to local IP printers is sensitive to network policy, browser permissions, and HTTPS mixed-content restrictions.",
    "The admin file manager writes to a mutable shared filesystem location outside the repo, so bad environment configuration can expose or orphan operational files.",
    "This repo currently carries live local modifications in deployment and RTV label files, so future automation must avoid assuming a clean worktree.",
    "The MARS audit flow assumes sequential wedge-style scanning; truly concurrent scan submissions could bypass duplicate detection without additional locking.",
    "Strict-mode reconciliation currently uses a conservative status helper that may need refinement as real MARS status vocabulary evolves.",
    "There are no obvious automated tests in the tracked tree, increasing regression risk around auth, printing, and pipeline behavior."
  ],
