{
  "name": "temcotools",
  "purpose": "Internal Temco warehouse operations web app that centralizes PIN-authenticated tooling for MARS tracking and audits, MARS return labels, batch barcode generation, CSV report pipelines, admin user management, and shared file exchange.",
  "status": "active Next.js operations portal with Prisma-backed auth/admin flows, MARS import/audit/reconciliation workflows, and browser-assisted printing utilities",
  "repo_role_in_system": "Single-repo internal operations surface for warehouse staff and administrators",
  "related_repos": [
    "stronghold"
  ],
  "depends_on": [
    "Next.js App Router",
    "React",
    "Prisma",
    "PostgreSQL",
    "Docker Compose",
    "iron-session",
    "bcryptjs"
  ],
  "entrypoints": [
    "app/page.tsx",
    "app/(auth)/signin/page.tsx",
    "app/api/auth/login/route.ts",
    "app/api/admin/users/route.ts",
    "app/api/admin/files/route.ts",
